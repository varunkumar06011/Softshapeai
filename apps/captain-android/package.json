{
  "name": "softshape-captain-android",
  "version": "19.3.0",
  "description": "SoftShape Captain Android App (Capacitor)",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "cd ../.. && npx vite build",
    "sync": "npx cap sync android",
    "build": "npm run build:web && npx cap sync android",
    "open": "npx cap open android",
    "apk": "npm run build:web && npx cap sync android && npx cap build android --apk"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/status-bar": "^8.0.2",
    "@capacitor-firebase/authentication": "^8.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1"
  }
}
