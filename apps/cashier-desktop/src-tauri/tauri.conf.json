{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoftShape Cashier",
  "version": "11.5.0",
  "identifier": "ai.softshape.cashier",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SoftShape Cashier",
        "url": "index.html",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://softshape-backend-production.up.railway.app/api/updates/cashier/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwRDQwOUM5NEExNzc2MDcKUldRSGRoZEt5UW5VUUI3R1hEUUNLNE5sZitnZVRaaXJURjhReWN3Qld6WFVzSTNDREcrcWRka0UK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../../../softshape-print-agent/softshape-print-agent/edge-server/edge-server.exe"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
