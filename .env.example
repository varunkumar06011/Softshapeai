# Softshape Frontend — Environment Variables
# Copy this file to .env.local (or .env) and fill in the values.

# (required) Backend API URL.
# Example for local development:
VITE_API_URL=http://localhost:3000

# (optional) Override the Windows Print Agent download URL shown in Admin → Printers.
# If not set, the UI falls back to the hardcoded GitHub release URL.
VITE_PRINT_AGENT_DOWNLOAD_URL=

# (optional) Sentry DSN for frontend error tracking.
VITE_SENTRY_DSN=
