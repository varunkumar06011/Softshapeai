# Softshape Frontend — Environment Variables
# Copy this file to .env.local (or .env) and fill in the values.

# (required) Backend API URL.
# Example for local development:
VITE_API_URL=http://localhost:3000

# (optional) Override the Windows Print Agent download URL shown in Admin → Printers.
# If not set, the UI falls back to the hardcoded GitHub release URL.
VITE_PRINT_AGENT_DOWNLOAD_URL=

# (optional) Desktop and Android app download URLs shown in Admin → Settings → Download Apps.
# If not set, the UI shows "Contact support to enable this download."
VITE_CASHIER_DESKTOP_DOWNLOAD_URL=https://github.com/varunkumar06011/Softshapeai/releases/download/v1.1.7/SoftShape.Cashier_0.1.0_x64-setup.exe
VITE_CASHIER_ANDROID_DOWNLOAD_URL=https://github.com/varunkumar06011/Softshapeai/releases/download/v1.1.7/cashier-android.apk
VITE_ADMIN_DESKTOP_DOWNLOAD_URL=https://github.com/varunkumar06011/Softshapeai/releases/download/v1.1.7/SoftShape.Admin_0.1.0_x64-setup.exe
VITE_ADMIN_ANDROID_DOWNLOAD_URL=https://github.com/varunkumar06011/Softshapeai/releases/download/v1.1.7/admin-android.apk
VITE_CAPTAIN_ANDROID_DOWNLOAD_URL=https://github.com/varunkumar06011/Softshapeai/releases/download/v1.1.7/captain-android.apk

# (optional) Enable service worker in dev mode for testing offline features locally.
# VITE_ENABLE_SW_DEV=true

# (optional) Firebase config (public client-side keys). Required for phone OTP in onboarding.
VITE_FIREBASE_API_KEY=AIzaSyD7OBT4VOtniMIGWSkpCVHV6wPsdJZKqy4
VITE_FIREBASE_AUTH_DOMAIN=softshapeai-14324.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=softshapeai-14324
VITE_FIREBASE_APP_ID=

# (optional) Sentry DSN for frontend error tracking.
VITE_SENTRY_DSN=https://0265523fc50be65aad6018cb11266b19@o4511625453699072.ingest.us.sentry.io/4511625461497856
