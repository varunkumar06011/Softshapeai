# No trailing slash on the URL (avoids //api/... broken requests)
VITE_API_URL=https://softshape-backend.onrender.com
VITE_BACKEND_URL=https://softshape-backend.onrender.com

# Login credentials — copy to .env and fill in real values (never commit .env)
VITE_CASHIER_EMAIL=change_me
VITE_CASHIER_PASSWORD=change_me
VITE_MANAGER_EMAIL=change_me
VITE_MANAGER_PASSWORD=change_me
VITE_ADMIN_EMAIL=change_me
VITE_ADMIN_PASSWORD=change_me

# Cloudinary — direct upload from browser (preset must be Unsigned)
VITE_CLOUDINARY_CLOUD_NAME=dnlhxmtqu
VITE_CLOUDINARY_UPLOAD_PRESET=softshape-vgrand-menu

# Backend only — required to restore liquor images from Cloudinary media library
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Printer names for QZ Tray
VITE_KITCHEN_PRINTER_NAME=KITCHEN_PRINTER
VITE_BAR_PRINTER_NAME=BAR PRINTER
VITE_BILLING_PRINTER_NAME=BAR PRINTER
VITE_KOT_FAMILY_PRINTER_NAME=KOT FAMILY
VITE_DINE_IN_BILL_PRINTER_NAME=Dine in Bill
VITE_KOT_PRINTER_NAME=KOT PRINTER
